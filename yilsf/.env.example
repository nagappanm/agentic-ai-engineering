# --- YILSF configuration ------------------------------------------------------
# The framework talks to Anthropic by default. Copy this file to `.env` and set
# your key, or run everything fully offline with the deterministic mock provider.

# Your Anthropic API key (only needed for the real provider).
ANTHROPIC_API_KEY=

# Which backend the pipeline should call:
#   anthropic  — real Claude models via the direct API, needs ANTHROPIC_API_KEY
#   vertex     — Claude on Google Vertex AI, authenticated with GCP ADC (no key)
#   mock       — deterministic, offline; used by the tests and demos
# If left blank, YILSF auto-detects: CLAUDE_CODE_USE_VERTEX=1 -> vertex,
# else ANTHROPIC_API_KEY present -> anthropic, else -> mock.
YILSF_PROVIDER=

# --- Vertex AI (only when YILSF_PROVIDER=vertex) -------------------------------
# No API key: credentials come from Application Default Credentials — workload
# identity on GCP, `gcloud auth application-default login`, or a service-account
# key in GOOGLE_APPLICATION_CREDENTIALS (the same chain Claude Code uses).
# Region + project fall back to the standard CLOUD_ML_REGION /
# ANTHROPIC_VERTEX_PROJECT_ID vars if these are unset.
YILSF_VERTEX_REGION=us-east5
YILSF_VERTEX_PROJECT_ID=
# Vertex model IDs differ from the direct API (they carry an @version suffix).
# Set the two models below to what your project has enabled in Model Garden,
# e.g. YILSF_DEV_MODEL=claude-sonnet-4-5@20250929

# Model selection. Mirrors the parent repo: a fast model for generation/critique
# and the most capable model reserved for the final stability (Samadhi) check.
YILSF_DEV_MODEL=claude-sonnet-4-6
YILSF_REASONING_MODEL=claude-opus-4-8

# Generation ceiling per LLM call.
YILSF_MAX_TOKENS=2048
